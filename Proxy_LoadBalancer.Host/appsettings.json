{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Proxy": {
    "Defaults": {
      "LoadBalancing": "RoundRobin",
      "PathMatch": "Prefix",
      "Timeouts": {
        "ConnectSeconds": 5,
        "ReadSeconds": 30,
        "WriteSeconds": 30
      },
      "HealthCheck": {
        "Path": "/health",
        "IntervalSeconds": 10,
        "TimeoutSeconds": 3,
        "UnhealthyThreshold": 2,
        "HealthyThreshold": 2
      },
      "ForwardHeaders": [
        "X-Real-IP",
        "X-Forwarded-For",
        "X-Forwarded-Proto",
        "X-Forwarded-Host"
      ]
    },
    "Clusters": {
      "orders-cluster": {
        "LoadBalancing": "RoundRobin",
        "Destinations": [
          { "Address": "http://localhost:5200" },
          { "Address": "http://localhost:5201" },
          { "Address": "http://localhost:5202" }
          //{
          //  "Address": "https://localhost:5001",
          //  "Weight": 1
          //},
          //{
          //  "Address": "http://localhost:5002",
          //  "Weight": 2
          //}
        ]
      },
      "users-cluster": {
        "LoadBalancing": "LeastConnections",
        "Destinations": [
          {
            "Address": "http://localhost:5003"
          }
        ]
      }
    },
    "Routes": [
      {
        "RouteId": "orders-route",
        "ClusterId": "orders-cluster",
        "Transform": null,
        "Priority": 1,
        "Match": {
          "Path": "/api/orders",
          "PathMatch": "Prefix",
          "Methods": [ "GET", "POST", "PUT", "DELETE" ]
        },
        "HealthCheck": {
          "Path": "/health/orders"
        }
      },
      {
        "RouteId": "users-route",
        "ClusterId": "users-cluster",
        "Transform": {
          "RemovePrefix": true
        },
        "Match": {
          "Path": "/api/users",
          "PathMatch": "Prefix"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
