{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Proxy": {
    "Defaults": {
      "TimeoutSeconds": 30,
      "ForwardHeaders": [ "X-Real-IP", "X-Forwarded-For", "X-Forwarded-Proto" ]
    },
    "Routes": [
      {
        "Path": "/api/orders",
        "PathMatch": "Prefix",
        "LoadBalancing": "RoundRobin",
        "HealthCheck": {
          "Path": "/health",
          "IntervalSeconds": 10,
          "TimeoutSeconds": 3,
          "UnhealthyThreshold": 2
        },
        "Timeouts": {
          "ConnectSeconds": 5,
          "ReadSeconds": 30
        },
        "Backends": [
          {
            "Url": "http://localhost:5001",
            "Weight": 1
          },
          {
            "Url": "http://localhost:5002",
            "Weight": 2
          }
        ]
      },
      {
        "Path": "/api/users",
        "PathMatch": "Prefix",
        "LoadBalancing": "LeastConnections",
        "HealthCheck": {
          "Path": "/health",
          "IntervalSeconds": 10,
          "TimeoutSeconds": 3,
          "UnhealthyThreshold": 2
        },
        "Backends": [
          {
            "Url": "http://localhost:5003",
            "Weight": 1
          }
        ]
      }
    ]
  },
  "AllowedHosts": "*"
}
