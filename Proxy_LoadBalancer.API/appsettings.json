{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Proxy": {
    "Routes": [
      {
        "Path": "/api/orders",
        "Backends": [
          {
            "Url": "http://localhost:5001",
            "Weight": 1
          },
          {
            "Url": "http://localhost:5002",
            "Weight": 2
          }
        ],
        "LoadBalancing": "RoundRobin",
        "HealthCheck": "/health"
      },
      {
        "Path": "/api/users",
        "Backends": [
          {
            "Url": "http://localhost:5003",
            "Weight": 1
          }
        ],
        "LoadBalancing": "LeastConnections"
      }
    ]
  },
  "AllowedHosts": "*"
}
